#!/usr/bin/env bash

set -e

RECONFIGURE=0
for arg in "$@"; do
  case "$arg" in
    --reconfigure) RECONFIGURE=1 ;;
    -h|--help)
      cat <<EOF
Usage: ./install [--reconfigure]

  --reconfigure  Re-prompt for work git identity and PATH overlays even if
                 ~/.gitconfig-work.local or ~/.zprofile.local already exist.
EOF
      exit 0
      ;;
    *)
      echo "Unknown flag: $arg" >&2
      exit 2
      ;;
  esac
done

echo "$OSTYPE $(uname)"

case $(uname) in
Darwin)
  xcode-select --install | 2>/dev/null
  ;;
Linux)
  sudo apt update
  sudo apt upgrade -y
  sudo apt install zsh podman -y
  sudo chsh -s $(which zsh) $USER
  export PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"
  ;;
esac

# Ensure Homebrew is installed and on PATH before we need it for prompts/bundle.
if ! command -v brew >/dev/null 2>&1; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
case $(uname) in
Darwin)
  [ -x /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
  ;;
Linux)
  [ -x /home/linuxbrew/.linuxbrew/bin/brew ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
  ;;
esac

# Install gum for nicer interactive prompts (falls back to plain read if unavailable).
command -v gum >/dev/null 2>&1 || brew install gum || true

scaffold_local() {
  local target="$1"
  local body="$2"
  if [ ! -f "$target" ]; then
    printf '%s\n' "$body" >"$target"
    echo "Created overlay stub: $target"
  fi
}

interactive() {
  [ -z "$DOTS_NONINTERACTIVE" ] && [ -t 0 ]
}

has_gum() { command -v gum >/dev/null 2>&1; }

prompt() {
  # prompt "Question" "default" -> echoes answer
  local question="$1"
  local default="$2"
  local answer
  if has_gum; then
    answer=$(gum input --prompt "$question: " --placeholder "${default:-leave blank to skip}" --value "$default")
    echo "$answer"
  elif [ -n "$default" ]; then
    read -r -p "$question [$default]: " answer </dev/tty
    echo "${answer:-$default}"
  else
    read -r -p "$question (blank to skip): " answer </dev/tty
    echo "$answer"
  fi
}

confirm() {
  # confirm "Question" -> returns 0 if yes
  local question="$1"
  if has_gum; then
    gum confirm "$question"
  else
    local answer
    read -r -p "$question [y/N]: " answer </dev/tty
    [[ "$answer" =~ ^[Yy] ]]
  fi
}

pick_op_signing_key() {
  # Echoes an ssh public key pulled from 1Password, or empty on failure/cancel.
  command -v op >/dev/null 2>&1 || return 0
  op account list >/dev/null 2>&1 || return 0

  local items item_id key
  items=$(op item list --categories "SSH Key" --format json 2>/dev/null) || return 0
  [ -z "$items" ] || [ "$items" = "[]" ] && return 0

  if has_gum; then
    local titles choice
    titles=$(echo "$items" | /usr/bin/python3 -c 'import json,sys
for i in json.load(sys.stdin): print(f"{i[\"id\"]}\t{i[\"title\"]}")' 2>/dev/null)
    [ -z "$titles" ] && return 0
    choice=$(echo "$titles" | gum choose --header "Select 1Password SSH Key for git signing (esc to skip)") || return 0
    item_id=$(echo "$choice" | cut -f1)
  else
    echo "1Password SSH Keys:" >&2
    echo "$items" | /usr/bin/python3 -c 'import json,sys
for i in json.load(sys.stdin): print(f"  {i[\"id\"]}  {i[\"title\"]}")' >&2
    read -r -p "Paste item id (blank to skip): " item_id </dev/tty
  fi

  [ -z "$item_id" ] && return 0
  key=$(op item get "$item_id" --fields "public key" --reveal 2>/dev/null) || return 0
  echo "$key"
}

setup_gitconfig_work() {
  local target="$HOME/.gitconfig-work.local"
  if [ -f "$target" ] && [ "$RECONFIGURE" != "1" ]; then
    echo "Skipping $target (exists; pass --reconfigure to reprompt)"
    return
  fi
  echo
  echo "-- Work git identity (used for repos under ~/git/work/**) --"
  local name email key
  name=$(prompt "Work git name" "$(git config --global user.name)")
  email=$(prompt "Work git email" "")
  key=$(pick_op_signing_key)
  if [ -z "$key" ]; then
    key=$(prompt "Work ssh signing key (public key string)" "")
  else
    echo "Using 1Password SSH key for signing."
  fi
  {
    echo "[user]"
    [ -n "$name" ] && printf '\tname = %s\n' "$name"
    [ -n "$email" ] && printf '\temail = %s\n' "$email"
    [ -n "$key" ] && printf '\tsigningkey = %s\n' "$key"
  } >"$target"
  echo "Wrote $target"
}

setup_zprofile_local() {
  local target="$HOME/.zprofile.local"
  if [ -f "$target" ] && [ "$RECONFIGURE" != "1" ]; then
    echo "Skipping $target (exists; pass --reconfigure to reprompt)"
    return
  fi
  echo
  echo "-- Work login-shell PATH additions (e.g. project .bin directories) --"
  local paths=()
  while confirm "Add a PATH entry to ~/.zprofile.local?"; do
    local p
    p=$(prompt "PATH entry (absolute path)" "")
    [ -n "$p" ] && paths+=("$p")
  done
  {
    echo '# Local zprofile overlay — login-shell PATH additions. Not tracked.'
    for p in "${paths[@]}"; do
      printf 'export PATH="$PATH:%s"\n' "$p"
    done
  } >"$target"
  echo "Wrote $target"
}

# Unattended stubs for overlays that rarely need seed content.
scaffold_local "$HOME/.zshenv.local" '# Local zshenv overlay — env vars, secrets, work paths. Not tracked.'
scaffold_local "$HOME/.zshrc.local" '# Local zshrc overlay — interactive shell tweaks. Not tracked.'
scaffold_local "$HOME/.aliases.local" '# Local aliases overlay. Not tracked.'
scaffold_local "$HOME/.profile.local" '# Local profile overlay (bash fallback). Not tracked.'
scaffold_local "$HOME/.Brewfile.local" '# Local Brewfile overlay — work-only taps/casks. Not tracked.'

if interactive; then
  setup_gitconfig_work
  setup_zprofile_local
else
  scaffold_local "$HOME/.gitconfig-work.local" $'[user]\n\tname = \n\temail = \n\tsigningkey = '
  scaffold_local "$HOME/.zprofile.local" '# Local zprofile overlay — login-shell PATH additions. Not tracked.'
fi

# From here down, individual failures shouldn't abort the whole install.
set +e

# If ~/.config is already a symlink into this repo's dots/.config, stow is a
# no-op (source and target are the same tree) — skip it to avoid spurious
# conflicts. Otherwise stow normally.
if [ -L "$HOME/.config" ] && [ "$(readlink -f "$HOME/.config")" = "$(readlink -f ./dots/.config)" ]; then
  echo "Skipping stow: ~/.config already symlinks into dots/.config"
else
  (cd dots && stow -t ~/.config .config)
fi

# .aws/ is gitignored; .ssh stays tracked with --assume-unchanged for now.
git update-index --assume-unchanged ./dots/.ssh/** 2>/dev/null

[ -d ~/.config/op ] && chmod 700 ~/.config/op

brew bundle install --global

[ -f "$HOME/.Brewfile.local" ] && brew bundle install --file="$HOME/.Brewfile.local"

setup_brew_launchd() {
  [ "$(uname)" = "Darwin" ] || return 0
  local src_dir="$PWD/dots/Library/LaunchAgents"
  local dst_dir="$HOME/Library/LaunchAgents"
  mkdir -p "$dst_dir" "$HOME/.cache/dot-brew"
  local plist label dst
  for plist in "$src_dir"/com.rizowski.brew-*.plist; do
    [ -f "$plist" ] || continue
    label=$(basename "$plist" .plist)
    dst="$dst_dir/$(basename "$plist")"
    cp "$plist" "$dst"
    launchctl bootout "gui/$UID/$label" 2>/dev/null
    launchctl bootstrap "gui/$UID" "$dst"
  done
  # Seed the summary so the first new shell has something to print.
  [ -x "$HOME/bin/brew-check" ] && "$HOME/bin/brew-check" >/dev/null 2>&1 &
}

setup_brew_launchd
