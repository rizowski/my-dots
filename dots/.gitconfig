[alias]
co = checkout
st = status
lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
la = !git lg --all
update = "!f(){ git fetch origin \"$1\" && git pull --rebase --autostash origin \"$1\"; }; f"
bl = !git branch -l --color --sort -committerdate --format='%(committerdate:relative) - %(refname:short)' | grep -v 'HEAD' # | head -n 10
blr = !git branch -r --color --sort -committerdate --format='%(committerdate:relative) - %(refname:short)' | grep -v 'HEAD' | head -n 10
oc = checkout
amend = commit --amend --no-edit
unstage = reset HEAD --
last = log -1 HEAD --stat
undo = reset --soft HEAD~1
root = rev-parse --show-toplevel
aliases = !git config --get-regexp ^alias\\. | sed 's/^alias\\.//'

#[remote "origin"]
#  fetch = +refs/pull/*/head:refs/remotes/origin/pr/*
[mergetool]
keepTemporaries = false
trustExitCode = false
keepBackup = false
prompt = false

[commit]
verbose = true

[user]
name = Colten Rouska
	email = crouska@gmail.com

[includeIf "gitdir:/Users/**"]
path=~/.gitconfig-mac

[includeIf "gitdir:/home/**"]
path=~/.gitconfig-linux

[includeIf "gitdir:~/git/work/**"]
path = ~/.gitconfig-work.local

[core]
autocrlf = input
pager = delta
fsmonitor = true
untrackedCache = true
[pull]
rebase = true
[init]
defaultBranch = main

[pager]
diff = delta
log = delta
reflog = delta
show = delta

[diff]
algorithm = histogram
colorMoved = zebra
renames = true
mnemonicPrefix = true

[merge]
conflictstyle = zdiff3

[branch]
sort = -committerdate

[tag]
sort = version:refname

[column]
ui = auto
[delta]
features = side-by-side line-numbers decorations dark
plus-style = syntax "#003800"
minus-style = syntax "#3f0001"
syntax-theme = Monokai Extended
navigate = true

[delta "plain"]
features = dark
navigate = true

[interactive]
diffFilter = delta --color-only --features=interactive

[rebase]
autostash = true
updateRefs = true
[push]
autoSetupRemote = true
[color]
ui = auto
[pack]
	usePathWalk = true
[fetch]
prune = true
pruneTags = true
all = true
fsckObjects = true

[transfer]
fsckObjects = true

[receive]
fsckObjects = true

[help]
autocorrect = prompt
[rerere]
enabled = true
autoupdate = true
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
