#!/bin/bash

set -u

brew=/opt/homebrew/bin/brew
cache_dir="$HOME/.cache/dot-brew"
last_upgrade="$cache_dir/last-upgrade"

mkdir -p "$cache_dir"

min_interval_days=6
last=$(cat "$last_upgrade" 2>/dev/null || echo 0)
now=$(date +%s)
if [ $((now - last)) -lt $((min_interval_days * 86400)) ]; then
  echo "Skipping: last upgrade was less than ${min_interval_days} days ago"
  exit 0
fi

echo "Starting to update brew"
"$brew" update

echo "Upgrading outdated software"
# Detach stdin so casks needing sudo fail fast under launchd (no TTY)
# instead of hanging. Failures are re-reported in the next brew-check.
"$brew" upgrade </dev/null # --greedy

echo "Cleaning up casks and brews"
"$brew" cleanup --prune 25

date +%s >"$last_upgrade"

if [ -x "$HOME/bin/brew-check" ]; then
  "$HOME/bin/brew-check" || true
fi

echo "Completed update"
