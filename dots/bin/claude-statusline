#!/usr/bin/env bash
input=$(cat)

{ read -r cwd
  read -r model
  read -r used_pct
  read -r five_hour
  read -r five_hour_resets_at
  read -r seven_day
  read -r seven_day_resets_at
  read -r vim_mode
  read -r worktree_branch
} < <(jq -r '
  .workspace.current_dir // .cwd // "",
  .model.display_name // "",
  .context_window.used_percentage // "",
  .rate_limits.five_hour.used_percentage // "",
  .rate_limits.five_hour.resets_at // "",
  .rate_limits.seven_day.used_percentage // "",
  .rate_limits.seven_day.resets_at // "",
  .vim.mode // "",
  .worktree.branch // ""
' <<<"$input")

now=$(date +%s)

RST='\033[0m' DIM='\033[2m'
CYN='\033[36m' GRN='\033[32m' YEL='\033[33m' RED='\033[31m' MAG='\033[35m' BLU='\033[34m'

color_pct() {
  local v=$(printf "%.0f" "$1")
  if [ "$v" -ge 80 ]; then echo "$RED"
  elif [ "$v" -ge 50 ]; then echo "$YEL"
  else echo "$GRN"; fi
}

color_pace() {
  local u="$1" sl="$2" near="$3" elapsed_pct="$4"
  if [ "$sl" -lt "$near" ]; then
    local colors=("$RED" "$YEL" "$GRN" "$CYN" "$BLU" "$MAG")
    printf '%s' "${colors[$(( now % 6 ))]}"
    return
  fi
  if [ "$elapsed_pct" -le 0 ]; then
    printf '%s' "$GRN"
    return
  fi
  local ratio=$(( u * 100 / elapsed_pct ))
  if [ "$ratio" -ge 200 ]; then printf '%s' "$RED"
  elif [ "$ratio" -gt 100 ]; then printf '%s' "$YEL"
  else printf '%s' "$GRN"
  fi
}

rainbow() {
  local text="$1"
  local colors=("31" "33" "32" "36" "34" "35")
  local n=${#colors[@]}
  local phase=$(( now % n ))
  local result="" i=0 len=${#text}
  while [ $i -lt $len ]; do
    result+="\033[1;${colors[$(( (i + phase) % n ))]}m${text:$i:1}"
    i=$(( i + 1 ))
  done
  printf '%s%b' "$result" "$RST"
}

fmt_countdown() {
  local sl="$1" near="$2" u="$3" elapsed_pct="$4"
  [ "$sl" -le 0 ] && return
  local h=$(( sl / 3600 )) m=$(( (sl % 3600) / 60 )) t
  if [ "$h" -gt 0 ]; then t="${h}h${m}m"; else t="${m}m"; fi
  if [ "$sl" -lt "$near" ]; then
    rainbow "(${t})"
    return
  fi
  local c="$GRN"
  if [ "$elapsed_pct" -ge 5 ] && [ "$u" -gt 0 ]; then
    local ratio=$(( u * 100 / elapsed_pct ))
    if [ "$ratio" -gt 150 ]; then c="$RED"
    elif [ "$ratio" -gt 100 ]; then c="$YEL"; fi
  fi
  printf '%s' "${c}(${t})${RST}"
}

render_window() {
  local label="$1" pct="$2" resets_at="$3"
  [ -z "$pct" ] && return
  local p=$(printf "%.0f" "$pct") c part
  if [ -n "$resets_at" ]; then
    local total near
    case "$label" in
      5h) total=18000;  near=3600  ;;
      7d) total=604800; near=86400 ;;
    esac
    local sl=$(( resets_at - now ))
    local elapsed_pct=$(( (total - sl) * 100 / total ))
    [ "$elapsed_pct" -lt 0 ] && elapsed_pct=0
    [ "$elapsed_pct" -gt 100 ] && elapsed_pct=100
    c=$(color_pace "$p" "$sl" "$near" "$elapsed_pct")
    part="${label}:${c}${p}%${RST}${DIM}/${elapsed_pct}%${RST}$(fmt_countdown "$sl" "$near" "$p" "$elapsed_pct")"
  else
    c=$(color_pct "$pct")
    part="${label}:${c}${p}%${RST}"
  fi
  printf ' %b|%b %s' "$DIM" "$RST" "$part"
}

cwd="${cwd/#$HOME\/git\//}"
cwd="${cwd/#$HOME/~}"

branch=""
if [ -n "$worktree_branch" ]; then
  branch="$worktree_branch"
elif [ -n "$cwd" ]; then
  real="${cwd/#\~/$HOME}"
  branch=$(git -C "$real" symbolic-ref --short HEAD 2>/dev/null || git -C "$real" rev-parse --short HEAD 2>/dev/null)
fi

wt=""
if [[ "$cwd" == */.claude/worktrees/* ]]; then
  cwd="${cwd#*/.claude/worktrees/}"   # keep worktree name + deeper path
  trees=(🌳 🌲 🌴 🎄 🎋 🌱 🎍 🪴 🌿)
  wt="${trees[$(( now % ${#trees[@]} ))]} "
fi

out=""
[ -n "$cwd" ] && out="${GRN}${wt}${RST}${CYN}${cwd}${RST}"
[ -n "$branch" ] && out="${out} ${DIM}on${RST} ${GRN}${branch}${RST}"
[ -n "$model" ] && out="${out} ${DIM}|${RST} ${MAG}${model}${RST}"

# %u: 1=Mon … 7=Sun
read -r la_dow la_hour < <(TZ=America/Los_Angeles date +'%u %H')
if [ "$la_dow" -ge 1 ] && [ "$la_dow" -le 5 ] && [ "$la_hour" -ge 9 ] && [ "$la_hour" -lt 18 ]; then
  out="${out} ${DIM}|${RST} ${RED}PEAK${RST}"
else
  out="${out} ${DIM}|${RST} ${GRN}off-peak${RST}"
fi

if [ -n "$used_pct" ]; then
  p=$(printf "%.0f" "$used_pct")
  out="${out} ${DIM}| ctx:${RST} $(color_pct "$used_pct")${p}%${RST}"
fi

out="${out}$(render_window 5h "$five_hour" "$five_hour_resets_at")"
out="${out}$(render_window 7d "$seven_day" "$seven_day_resets_at")"

if [ -n "$vim_mode" ]; then
  [ "$vim_mode" = "INSERT" ] && vc="$YEL" || vc="$BLU"
  out="${out} ${DIM}|${RST} ${vc}${vim_mode}${RST}"
fi

printf '%b' "$out"
