#!/bin/bash
# Paired with com.rizowski.brew-check launchd agent; safe to invoke manually.

set -u

brew=/opt/homebrew/bin/brew
cache_dir="$HOME/.cache/dot-brew"
summary="$cache_dir/summary.txt"
last_upgrade="$cache_dir/last-upgrade"
upgrade_interval_days=7

mkdir -p "$cache_dir"

"$brew" update >/dev/null 2>&1 || true

outdated=$("$brew" outdated --verbose 2>/dev/null)
count=$(printf '%s\n' "$outdated" | grep -c .)

if [ "$count" -eq 0 ]; then
  : >"$summary"
  exit 0
fi

last=$(cat "$last_upgrade" 2>/dev/null || echo 0)
now=$(date +%s)
next=$((last + upgrade_interval_days * 86400))

if [ "$next" -le "$now" ]; then
  when="on next scheduled run (overdue)"
else
  when=$(date -r "$next" "+%a %b %d %H:%M")
fi

{
  printf '== brew: %d outdated ==\n' "$count"
  printf '%s\n' "$outdated"
  printf 'next upgrade: %s\n' "$when"
} >"$summary"
